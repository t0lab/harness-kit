{
  "name": "@harness-kit/cli",
  "version": "0.2.0-beta.10",
  "description": "CLI tool that scaffolds AI agent harness environments for projects",
  "license": "MIT",
  "type": "module",
  "bin": {
    "harness-kit": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "rules",
    "skills",
    "templates",
    "hooks",
    "git-hooks",
    "agents",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@harness-kit/core": "workspace:*",
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.0.0",
    "commander": "^14.0.0",
    "execa": "^9.0.0",
    "handlebars": "^4.7.0",
    "ink": "^7.0.0",
    "ink-text-input": "^6.0.0",
    "listr2": "^10.0.0",
    "react": "^19.2.5",
    "xstate": "^5.30.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14"
  }
}
